model Orders{
    id String @id @default(uuid())

    customer User @relation(fields:[customer_id],references:[id],onDelete: Cascade,onUpdate: Cascade)
    customer_id String

    subtotal_amount Int
    delivery_charge Int
    total_amount Int
    total_paid_amount Int @default(0)
    delivery_charge_status Boolean @default(false)

    phoneNumber String
    address String

    orderItems OrderItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([id])
    @@index([customer_id])
    @@map("orders")
}