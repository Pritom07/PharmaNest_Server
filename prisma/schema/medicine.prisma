model Medicines{
    id String @id @default(uuid())
    name String
    price Int
    stock Int
    manufacturer String
    img_url String

    medicine_Category Categories @relation(fields:[category_id],references:[id])
    category_id Int

    user_medicine User @relation(fields:[user_id],references: [id])
    user_id String

    createdAt DateTime @default(now())
    updatedAt DateTime? @updatedAt

    @@index([id])
    @@index([user_id])
    @@map("medicines")
}